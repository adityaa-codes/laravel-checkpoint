{
    "name": "adityaa-codes/laravel-checkpoint",
    "description": "Core package for database checkpoint, backup, and recovery operations in Laravel.",
    "keywords": [
        "Adityaa Codes",
        "laravel",
        "laravel-checkpoint"
    ],
    "homepage": "https://github.com/adityaa-codes/laravel-checkpoint",
    "license": "MIT",
    "authors": [
        {
            "name": "Aditya Gupta",
            "email": "mailadityaguptaa@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16",
        "symfony/process": "^7.0"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.1",
        "infection/infection": "^0.31.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "AdityaaCodes\\LaravelCheckpoint\\": "src/",
            "AdityaaCodes\\LaravelCheckpoint\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AdityaaCodes\\LaravelCheckpoint\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AdityaaCodes\\LaravelCheckpoint\\LaravelCheckpointServiceProvider"
            ],
            "aliases": {
                "LaravelCheckpoint": "AdityaaCodes\\LaravelCheckpoint\\Facades\\LaravelCheckpoint"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
